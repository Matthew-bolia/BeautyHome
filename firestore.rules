rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Les utilisateurs ne peuvent lire et modifier que leur propre profil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Règles pour les publications
    match /publications/{publicationId} {
      // N'importe qui peut lire les publications
      allow read: if request.auth != null;
      // Seuls les administrateurs (isAdmin == true) peuvent écrire
      allow write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}